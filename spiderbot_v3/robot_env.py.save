<?xml version="1.0"?>
<robot name="spdrbot">

  <link name="body">
    <visual>
      <geometry><box size="0.18 0.14 0.025"/></geometry>
      <material name="gray"><color rgba="0.5 0.5 0.5 1"/></material>
