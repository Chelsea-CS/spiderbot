<?xml version="1.0"?>
<robot name="spdrbot">

  <link name="body">
    <visual>
      <geometry><box size="0.48 0.36 0.075"/></geometry>
      <material name="gray"><color rgba="0.45 0.45 0.45 1"/></material>
